<?xml version="1.0" encoding="UTF-8"?>
<!--
    web.xml — the web application "deployment descriptor".
    It configures the whole web app for the servlet container (Tomcat).

    KEY POINTS (viva):
      - version="5.0" + the jakarta.ee namespace = Jakarta Servlet 5.0, which is
        why our servlets import jakarta.servlet.* (Tomcat 10). Old Tomcat 9 used
        javax.servlet.* — different namespace, would not compile here.
      - We do NOT declare <servlet>/<servlet-mapping> entries because each
        servlet maps itself with the @WebServlet("/...") annotation instead.
      - welcome-file = the default page served for the app root URL.
      - error-page = GLOBAL error handling: when a servlet sends HTTP 400/404/500,
        Tomcat shows our friendly JSP instead of a raw Java stack trace. This is
        a mandatory project requirement.
-->
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>Weather Dataset Management</display-name>

    <!-- Visiting .../MiniProject2/ serves index.jsp -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Map each HTTP error code to a custom, user-friendly page -->
    <error-page>
        <error-code>400</error-code>          <!-- Bad Request (bad input) -->
        <location>/error/400.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>          <!-- Not Found (unknown URL / id) -->
        <location>/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>          <!-- Internal Server Error (e.g. DB down) -->
        <location>/error/500.jsp</location>
    </error-page>

</web-app>
